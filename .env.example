# Copy this file to `.env` and fill in your own keys.
# `.env` is gitignored — never commit it.
#
# Preferred for web sessions: set these in the environment config (Manage
# environments → variables) instead of a file. The SessionStart hook also loads
# a local `.env` if present.

# Runway Gen-4 — AI b-roll generation (npm run gen). Key: https://dev.runwayml.com
RUNWAYML_API_SECRET=

# ClickUp API key — only needed if a project integrates with ClickUp
CLICKUP_API_KEY=

# OpenAI API key — only needed if a project uses OpenAI for text/image generation
OPENAI_API_KEY=
